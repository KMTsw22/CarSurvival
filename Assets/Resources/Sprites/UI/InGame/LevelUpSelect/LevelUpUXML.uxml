                    <ui:Label name="card-desc" text="Description" class="card-desc" style="width: 80%; height: 33%; padding-top: 0; padding-right: 0; padding-bottom: 30%; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 30px; justify-content: flex-end;" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="card-template2" class="levelup-card">
                <ui:VisualElement name="card-top" class="card-top" style="padding-top: 10%; padding-bottom: 0%; height: 100%; width: 100%;">
                    <ui:Label name="card-category" text="[Sub Weapon]" class="card-category" style="margin-top: 0; font-size: 20px; width: 80%; height: 20%; padding-top: 15%;" />
                    <ui:VisualElement name="card-icon" class="card-icon" style="width: 80%; height: 25%; margin-top: 10%; margin-bottom: 10%; padding-top: 0%; padding-bottom: 0%; padding-right: 0%; padding-left: 0%; margin-left: 0%;" />
                    <ui:Label name="card-desc" text="Description" class="card-desc" style="width: 80%; height: 33%; padding-top: 0; padding-right: 0; padding-bottom: 30%; padding-left: 0; margin-top: 0; margin-right: 0; margin-bottom: 0; margin-left: 0; font-size: 30px; justify-content: flex-end;" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="card-template3" class="levelup-card">
                <ui:VisualElement name="card-top" class="card-top" style="padding-top: 10%; padding-bottom: 0%; height: 100%; width: 100%;">
                    <ui:Label name="card-category" text="[Spell Book]" class="card-category" style="margin-top: 0; font-size: 20px; width: 80%; height: 20%; padding-top: 15%;" />
