<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/Resources/Sprites/UI/InGame/LevelUpSelect/LevelUp.uss?fileID=7433441132597879392&amp;guid=7520d42ad56ee3242b65eb10f5c2b139&amp;type=3#LevelUp" />
    <ui:VisualElement name="levelup-overlay" class="levelup-overlay">
